# Copy this file to .env and fill in your values
# .env is gitignored — never commit real secrets

# Change this to a long random string in production!
SECRET_KEY=change-me-to-a-long-random-secret-string

# Database (default is SQLite — change to PostgreSQL for production)
# DATABASE_URL=sqlite:///./invoiceapp.db
# DATABASE_URL=postgresql://user:password@localhost/invoicedb

# App settings
APP_HOST=0.0.0.0
APP_PORT=8000
